# Bundled Postgres in root docker-compose.yml: `true` adds compose profile `nebularr-bundled-postgres`
# (see COMPOSE_PROFILES). Set to `false` for app-only stack and point the Web UI setup at an external DB.
NEBULARR_BUNDLED_POSTGRES=true
# Docker Compose profiles (comma-separated). Bundled Postgres requires `nebularr-bundled-postgres`.
COMPOSE_PROFILES=nebularr-bundled-postgres

APP_VERSION=2.1.0
APP_GIT_SHA=release
APP_TIMEZONE=UTC
SCHEDULER_TIMEZONE=UTC
# Fernet key for encrypting stored secrets. Leave empty to let Nebularr generate and
# persist one under NEBULARR_RUNTIME_DIR on first start (recommended default).
APP_ENCRYPTION_KEY=

# Web UI / API authentication. Managed from the web UI (setup wizard or
# Integrations → Authentication); these env vars are overrides only:
#   AUTH_ENABLED=false  -> emergency escape hatch (lockout recovery)
#   AUTH_ENABLED=true   -> force enforcement on
#   AUTH_RECOVERY_PASSWORD -> temporary login when the password is lost
AUTH_ENABLED=
AUTH_RECOVERY_PASSWORD=
AUTH_SESSION_TTL_HOURS=168

# Egress policy for user-configured outbound URLs (integrations, alert webhooks):
# lan (default) blocks link-local/cloud-metadata ranges; strict allows public hosts
# only; open restores pre-2.0 behavior.
EGRESS_POLICY=lan

POSTGRES_DB=arranalytics
POSTGRES_USER=arradmin
POSTGRES_PASSWORD=arradmin
POSTGRES_PORT=5432

# Optional: set DATABASE_URL to skip the Web UI Postgres step (e.g. CI or advanced installs).
# Leave empty for the default first-run wizard, which waits for Postgres, runs migrations, and
# persists the URL under NEBULARR_RUNTIME_DIR (/app/data in compose).
DATABASE_URL=

NEBULARR_RUNTIME_DIR=/app/data

WEBHOOK_MAX_BODY_BYTES=262144

ALERT_SYNC_LAG_WARNING_SECONDS=3600
ALERT_SYNC_LAG_CRITICAL_SECONDS=7200
ALERT_WEBHOOK_QUEUE_WARNING=100
ALERT_WEBHOOK_QUEUE_CRITICAL=500
ALERT_WEBHOOK_URLS=
ALERT_WEBHOOK_TIMEOUT_SECONDS=10
ALERT_WEBHOOK_MIN_STATE=warning
ALERT_WEBHOOK_NOTIFY_RECOVERY=true

HTTP_TIMEOUT_SECONDS=15
HTTP_RETRY_ATTEMPTS=3
HTTP_MAX_PARALLEL_REQUESTS=4

# Root log level at process start. The Web UI can override and persist a level in the database (Integrations → Application logging).
LOG_LEVEL=INFO

SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE=1800
SQL_STATEMENT_TIMEOUT_MS=120000

# MyAnimeList + MAL-Dubs (optional). dubInfo.json is AGPL-3.0 — see upstream MAL-Dubs license.
# Register an app at https://myanimelist.net/apiconfig for MAL_CLIENT_ID.
MAL_CLIENT_ID=
MAL_DUB_INFO_URL=https://raw.githubusercontent.com/MAL-Dubs/MAL-Dubs/main/data/dubInfo.json
MAL_INGEST_ENABLED=false
MAL_MATCHER_ENABLED=false
MAL_TAGGING_ENABLED=false
MAL_JIKAN_ENABLED=true
MAL_INGEST_CRON=0 3 * * *
MAL_MATCHER_CRON=30 3 * * *
MAL_TAG_SYNC_CRON=0 4 * * *
MAL_MIN_REQUEST_INTERVAL_SECONDS=0.6
MAL_JIKAN_MIN_REQUEST_INTERVAL_SECONDS=1.0
MAL_MAX_IDS_PER_RUN=200
MAL_ALLOW_TITLE_YEAR_MATCH=false
ARR_DUB_TAG_LABEL=English-Dubbed-Anime

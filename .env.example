APP_VERSION=1.0.0
APP_GIT_SHA=release
APP_TIMEZONE=UTC
SCHEDULER_TIMEZONE=UTC
APP_ENCRYPTION_KEY=

POSTGRES_DB=arranalytics
POSTGRES_USER=arradmin
POSTGRES_PASSWORD=arradmin
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://arrapp:arrapp@postgres:5432/arranalytics

WEBHOOK_MAX_BODY_BYTES=262144

ALERT_SYNC_LAG_WARNING_SECONDS=3600
ALERT_SYNC_LAG_CRITICAL_SECONDS=7200
ALERT_WEBHOOK_QUEUE_WARNING=100
ALERT_WEBHOOK_QUEUE_CRITICAL=500
ALERT_WEBHOOK_URLS=
ALERT_WEBHOOK_TIMEOUT_SECONDS=10
ALERT_WEBHOOK_MIN_STATE=warning
ALERT_WEBHOOK_NOTIFY_RECOVERY=true

HTTP_TIMEOUT_SECONDS=15
HTTP_RETRY_ATTEMPTS=3
HTTP_MAX_PARALLEL_REQUESTS=4

SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE=1800
SQL_STATEMENT_TIMEOUT_MS=120000
